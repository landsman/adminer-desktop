<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleName</key>
	<string>Adminer Desktop</string>
	<key>CFBundleDisplayName</key>
	<string>Adminer Desktop</string>
	<key>CFBundleIdentifier</key>
	<string>org.adminer.desktop</string>
	<key>CFBundleExecutable</key>
	<string>adminer-desktop</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleIconFile</key>
	<string>AdminerDesktop.icns</string>
	<!-- Tracks the adminer release we bundle: that is the version a user cares about. -->
	<key>CFBundleShortVersionString</key>
	<string>@ADMINER_VERSION@</string>
	<key>CFBundleVersion</key>
	<string>@ADMINER_VERSION@</string>
	<key>LSMinimumSystemVersion</key>
	<string>11.0</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>cs</string>
	</array>
	<key>NSHighResolutionCapable</key>
	<true/>
	<!-- Not a background agent: it owns a window and belongs in the Dock. -->
	<key>LSUIElement</key>
	<false/>
</dict>
</plist>
